# ── HPC Agent — root .env.example ─────────────────────────────────────────────
# Copy to .env and fill in values before starting the runner.

# ── Runner ────────────────────────────────────────────────────────────────────
TBC_HOME=~/.hpc_agent
HPC_SHARED_STEP_TIMEOUT_MS=21600000
HPC_SHARED_STEP_OUTPUT_LIMIT=120000

# Optional provider keys for projects that explicitly set agentRuntime=api.
# The default local runtime is codex_cli and does not require these keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: password to protect the local API
TBC_PASSWORD=
